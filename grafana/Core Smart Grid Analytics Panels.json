      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": " Monthly Regional Energy Usage (Grouping by First Digit of ID)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
