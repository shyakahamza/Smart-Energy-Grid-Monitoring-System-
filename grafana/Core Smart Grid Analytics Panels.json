        "spec": {
          "id": 1,
          "title": "Real-Time Meter Readings (Last Hour)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "ffmr60wdbcgzkd"
                      },
                      "spec": {
                        "dataset": "postgres",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n  time_bucket('5 minutes', timestamp) AS time,\r\n  AVG(power) AS \"Average Power (kW)\",\r\n  MAX(power) AS \"Peak Meter Power (kW)\"\r\nFROM energy_readings\r\nWHERE timestamp >= NOW() - INTERVAL '1 hour'\r\nGROUP BY time\r\nORDER BY time ASC;\r\n",
                        "sql": {
