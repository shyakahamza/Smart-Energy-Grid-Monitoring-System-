                      },
                      "spec": {
                        "dataset": "postgres",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n  SUBSTRING(meter_id FROM 1 FOR 1) AS \"Region ID\",\r\n  CONCAT('Region ', SUBSTRING(meter_id FROM 1 FOR 1)) AS region_name,\r\n  SUM(total_energy) AS \"Monthly Consumption (kWh)\"\r\nFROM energy_readings_1d \r\nWHERE bucket >= DATE_TRUNC('month', NOW() - INTERVAL '1 month')\r\nGROUP BY \"Region ID\"\r\nORDER BY \"Monthly Consumption (kWh)\" DESC;\r\n",
