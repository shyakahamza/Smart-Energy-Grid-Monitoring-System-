      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Daily Consumption Patterns(Today vs Yesterday)",
          "description": "",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "grafana-postgresql-datasource",
                      "version": "v0",
                      "datasource": {
                        "name": "ffmr60wdbcgzkd"
                      },
                      "spec": {
                        "dataset": "postgres",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n  bucket AS time,\r\n  CASE \r\n    WHEN bucket >= DATE_TRUNC('day', NOW()) THEN 'Today'\r\n    ELSE 'Yesterday'\r\n  END AS metric,\r\n  SUM(total_energy) AS \"Total Energy Consumption (kWh)\"\r\nFROM energy_readings_1h \r\nWHERE bucket >= DATE_TRUNC('day', NOW() - INTERVAL '1 day')\r\nGROUP BY time, metric\r\nORDER BY time ASC;\r\n",
                        "sql": {
